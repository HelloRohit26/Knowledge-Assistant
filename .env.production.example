# Enterprise Knowledge Intelligence Platform — Production Environment Variables

# Gemini API Key (Required)
GEMINI_API_KEY=your_gemini_api_key_here

# Backend Database & Vector Store Settings
CHROMA_DB_PATH=./chroma_db
DATA_FOLDER=./data

# JWT Authentication Secret Key (Required for Production)
SECRET_KEY=change_this_to_a_secure_random_64_char_string

# Environment Mode
ENVIRONMENT=production
LOG_LEVEL=INFO
